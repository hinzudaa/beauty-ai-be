# Server
PORT=4000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/beauty?retryWrites=true&w=majority&appName=Cluster0

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# verify.mn — get your key at https://verify.mn/dashboard
# Required for phone verification. Fail-loud if missing.
VERIFY_MN_API_KEY=your_verify_mn_api_key_here

# Callback base URL (optional — if omitted, falls back to polling every 3s)
# Must be a public HTTPS URL that verify.mn can reach.
# Example: https://api.yourdomain.com
APP_BASE_URL=
